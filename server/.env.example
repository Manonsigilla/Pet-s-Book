PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
DB_PATH=./src/db/petsbook.sqlite

# Secret du poivre (HMAC) appliqué avant bcrypt. NE JAMAIS le stocker en BDD.
# Génère-en un avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_PEPPER=remplace-moi-par-un-secret-aleatoire-de-64-caracteres-hex

# Secret de signature des JWT. Doit être long, aléatoire et confidentiel.
JWT_SECRET=remplace-moi-aussi-par-un-secret-aleatoire-tres-long
JWT_EXPIRES_IN=24h

# --- Pipeline ETL (npm run dataset) — clés OPTIONNELLES (montent les quotas) ---
# The Cat API / The Dog API : https://thecatapi.com / https://thedogapi.com (clé gratuite)
THECATAPI_KEY=
THEDOGAPI_KEY=
# Austin Animal Center (Socrata) : https://data.austintexas.gov (jeton gratuit)
SODA_APP_TOKEN=
